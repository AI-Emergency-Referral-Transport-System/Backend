DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY='security key'
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=https://backend-django-v1.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TIME_ZONE=Africa/Nairobi
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=strongpass
DJANGO_ADMIN_USERNAME=admin

POSTGRES_ENGINE=django.contrib.gis.db.backends.postgis
POSTGRES_DB=ai_emergency
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@ai-emergency.local
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
